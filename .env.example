# ─── Database ────────────────────────────────────────────────
POSTGRES_USER=bma_user
POSTGRES_PASSWORD=change_me
POSTGRES_DB=bma_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# ─── Redis ───────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ─── Auth Service (JWT — EdDSA / Ed25519 key pair) ───────────
# Auth service SIGNS tokens with the private key.
# AI service VERIFIES tokens with the public key (no shared secret).
# Generate your own pair (do NOT reuse any committed example keys):
#   openssl genpkey -algorithm ed25519 -out priv.pem
#   openssl pkey -in priv.pem -pubout -out pub.pem
#   base64 -w0 priv.pem   # → JWT_PRIVATE_KEY_BASE64
#   base64 -w0 pub.pem    # → JWT_PUBLIC_KEY_BASE64
JWT_PRIVATE_KEY_BASE64=base64_encoded_pem_ed25519_private_key
JWT_PUBLIC_KEY_BASE64=base64_encoded_pem_ed25519_public_key
JWT_ACCESS_TOKEN_TTL_MINUTES=15
JWT_REFRESH_TOKEN_TTL_DAYS=7
AUTH_SERVICE_PORT=8001

# ─── AI Service ──────────────────────────────────────────────
AI_SERVICE_PORT=8002

# ─── AI Model API Keys ───────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# ─── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_REQUESTS_PER_HOUR=10

# ─── Environment ─────────────────────────────────────────────
ENVIRONMENT=development
